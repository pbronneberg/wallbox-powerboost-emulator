{
  "name": "wallbox-powerboost-emulator",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "platformio.platformio-ide",
        "openai.chatgpt"
      ]
    }
  },
  "postCreateCommand": "python -m pip install -r requirements.txt",
  "features": {}
}
